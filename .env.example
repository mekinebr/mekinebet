# FRONTEND - Supabase
VITE_SUPABASE_URL=cole_aqui
VITE_SUPABASE_ANON_KEY=cole_aqui

# FRONTEND - Firebase Web
VITE_FIREBASE_API_KEY=cole_aqui
VITE_FIREBASE_AUTH_DOMAIN=cole_aqui
VITE_FIREBASE_PROJECT_ID=cole_aqui
VITE_FIREBASE_STORAGE_BUCKET=cole_aqui
VITE_FIREBASE_MESSAGING_SENDER_ID=cole_aqui
VITE_FIREBASE_APP_ID=cole_aqui
VITE_FIREBASE_MEASUREMENT_ID=cole_aqui

# FRONTEND - Mercado Pago public key
VITE_MP_PUBLIC_KEY=cole_aqui

# BACKEND - Supabase service role, não usar no frontend
SUPABASE_SERVICE_ROLE_KEY=cole_aqui
SUPABASE_URL=cole_aqui

# BACKEND - Mercado Pago
MP_ACCESS_TOKEN=cole_aqui
MP_WEBHOOK_SECRET=opcional

# BACKEND - APIs Futebol
ODDS_API_KEY=cole_aqui
SPORTMONKS_TOKEN=cole_aqui
APIFOOTBALL_TOKEN=cole_aqui

# BACKEND - Firebase Admin
# Opção 1: caminho local do JSON baixado do Firebase
GOOGLE_APPLICATION_CREDENTIALS=./server/config/serviceAccountKey.json
# Opção 2: JSON em base64 para deploy em Vercel/Railway/Render
FIREBASE_SERVICE_ACCOUNT_BASE64=

# URLs públicas
APP_URL=http://localhost:5173
API_URL=http://localhost:3001
